{
  "collection": "carritos_abandonados",
  "description": "Captura carritos no convertidos a pedido. Cada documento representa el último estado del carrito antes del abandono. Usado para remarketing y análisis de fricción. cliente_id y items[].producto_id referencian PostgreSQL.",

  "indexes": [
    { "key": { "cliente_id": 1 },     "name": "idx_cliente" },
    { "key": { "estado": 1 },         "name": "idx_estado" },
    { "key": { "fecha_abandono": 1 }, "name": "idx_fecha" },
    {
      "key": { "fecha_recuperado": 1 },
      "expireAfterSeconds": 2592000,
      "partialFilterExpression": { "estado": "recuperado" },
      "name": "idx_ttl_recuperados_30dias"
    }
  ],

  "validator": {
    "$jsonSchema": {
      "bsonType": "object",
      "required": ["cliente_id", "items", "monto_total", "estado", "fecha_abandono"],
      "properties": {
        "cliente_id":     { "bsonType": "string" },
        "items":          { "bsonType": "array" },
        "monto_total":    { "bsonType": "double" },
        "estado":         { "bsonType": "string", "enum": ["activo", "recuperado", "expirado"] },
        "fecha_abandono": { "bsonType": "date" }
      }
    }
  },

