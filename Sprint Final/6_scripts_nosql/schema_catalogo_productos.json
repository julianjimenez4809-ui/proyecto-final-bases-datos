{
  "collection": "catalogo_productos",
  "description": "Enriquece la tabla producto de PostgreSQL con atributos variables, imágenes, tags y historial de precios. El _id es el mismo UUID que producto.producto_id en Supabase.",

  "indexes": [
    { "key": { "categoria": 1 }, "name": "idx_categoria" },
    { "key": { "tags": 1 }, "name": "idx_tags" },
    { "key": { "activo": 1, "precio_venta": 1 }, "name": "idx_activo_precio" },
    { "key": { "nombre": "text", "descripcion": "text", "tags": "text" }, "name": "idx_texto_busqueda" }
  ],

  "validator": {
    "$jsonSchema": {
      "bsonType": "object",
      "required": ["_id", "sku", "nombre", "categoria", "precio_venta", "activo"],
      "properties": {
        "_id":          { "bsonType": "string", "description": "UUID de producto en PostgreSQL" },
        "sku":          { "bsonType": "string" },
        "nombre":       { "bsonType": "string" },
        "descripcion":  { "bsonType": "string" },
        "categoria":    { "bsonType": "string" },
        "precio_venta": { "bsonType": "double" },
        "activo":       { "bsonType": "bool" },
        "imagenes":     { "bsonType": "array" },
        "tags":         { "bsonType": "array" },
        "especificaciones": { "bsonType": "object" },
        "historial_precios": { "bsonType": "array" }
      }
    }
  },

