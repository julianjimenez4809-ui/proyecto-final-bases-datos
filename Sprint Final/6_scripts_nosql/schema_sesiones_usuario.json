{
  "collection": "sesiones_usuario",
  "description": "Registra eventos de navegación por sesión: vistas de producto, búsquedas, clics en carrito. Modelo de bucket por día. El cliente_id referencia cliente.cliente_id de PostgreSQL.",

  "indexes": [
    { "key": { "cliente_id": 1, "fecha": -1 }, "name": "idx_cliente_fecha" },
    { "key": { "eventos.producto_id": 1 },      "name": "idx_evento_producto" },
    { "key": { "fecha": 1 }, "expireAfterSeconds": 7776000, "name": "idx_ttl_90dias" }
  ],

  "validator": {
    "$jsonSchema": {
      "bsonType": "object",
      "required": ["cliente_id", "sesion_id", "fecha", "eventos"],
      "properties": {
        "cliente_id": { "bsonType": "string", "description": "UUID de cliente en PostgreSQL (puede ser anónimo: 'anon_<fingerprint>')" },
        "sesion_id":  { "bsonType": "string" },
        "fecha":      { "bsonType": "date" },
        "dispositivo":{ "bsonType": "string" },
        "eventos":    { "bsonType": "array" }
      }
    }
  },

